<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1B1D21"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tv_picker_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select view"
        android:textColor="#7C6DF2"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <!-- Built-in views -->
    <LinearLayout
        android:id="@+id/ll_option_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:paddingVertical="7dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_dot_1"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tv_option_1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:maxLines="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_option_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:paddingVertical="7dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_dot_2"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tv_option_2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:maxLines="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_option_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:paddingVertical="7dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_dot_3"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tv_option_3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:maxLines="1" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="6dp"
        android:visibility="gone" />

    <!-- Project views -->
    <LinearLayout
        android:id="@+id/ll_option_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:paddingVertical="7dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_dot_4"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tv_option_4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:maxLines="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_option_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:paddingVertical="7dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_dot_5"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tv_option_5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:maxLines="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_option_6"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_row_bg"
        android:paddingVertical="7dp"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_dot_6"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_marginEnd="10dp"
            android:importantForAccessibility="no" />

        <TextView
            android:id="@+id/tv_option_6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:maxLines="1" />
    </LinearLayout>

</LinearLayout>
