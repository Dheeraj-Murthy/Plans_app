        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#888888"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
